{
  "compilerOptions": {
    "checkJs": false,
    "noEmit": true,
    "allowJs": true,
    "lib": ["dom", "dom.iterable", "es2022"],
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["js/**/*.js", "js/**/*.d.ts", "tools/**/*.mjs"]
}
